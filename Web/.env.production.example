# =============================================================================
# USM EAES — Production Template
# Copy to .env on the production server and fill every secret before deploy.
# =============================================================================

APP_NAME="USM EAES"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://eaes.usm.edu.ph
APP_TIMEZONE=Asia/Manila

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=eaes
DB_USERNAME=eaes
DB_PASSWORD=change-me
DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=.usm.edu.ph

CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_QUEUE=default
REDIS_CACHE_DB=1

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@usm.edu.ph"
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=https://eaes.usm.edu.ph
VITE_APP_NAME="${APP_NAME}"
VITE_API_URL="${APP_URL}/api"
SANCTUM_STATEFUL_DOMAINS=eaes.usm.edu.ph
SANCTUM_EXPIRATION=43200

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

EAES_ALLOWED_EMAIL_DOMAIN=usm.edu.ph
EAES_UNIVERSITY_NAME="University of Southern Mindanao"
EAES_SYNC_BATCH_SIZE=200
EAES_SYNC_CHUNK_SIZE=200
EAES_EVALUATION_WINDOW_HOURS=24
EAES_MOBILE_DEEP_LINK_SCHEME=eaes
EAES_FORCE_HTTPS=true
EAES_SECURITY_HEADERS=true
EAES_ENABLE_DEV_LOGIN=false

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
GEMINI_REQUEST_TIMEOUT=60
