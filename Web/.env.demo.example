# =============================================================================
# USM EAES — Local Demo Template
# Copy to .env for demo walkthroughs. Keep APP_DEBUG=false to match deployment.
# =============================================================================

APP_NAME="USM EAES"
APP_ENV=local
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://eaes-demo.local
APP_TIMEZONE=Asia/Manila

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=eaes
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

FRONTEND_URL=https://eaes-demo.local
VITE_APP_NAME="${APP_NAME}"
VITE_API_URL="${APP_URL}/api"
SANCTUM_STATEFUL_DOMAINS=eaes-demo.local
SANCTUM_EXPIRATION=43200

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

EAES_ALLOWED_EMAIL_DOMAIN=usm.edu.ph
EAES_UNIVERSITY_NAME="University of Southern Mindanao"
EAES_SYNC_BATCH_SIZE=200
EAES_SYNC_CHUNK_SIZE=200
EAES_EVALUATION_WINDOW_HOURS=24
EAES_MOBILE_DEEP_LINK_SCHEME=eaes
EAES_FORCE_HTTPS=true
EAES_SECURITY_HEADERS=true
EAES_ENABLE_DEV_LOGIN=false

GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
GEMINI_REQUEST_TIMEOUT=60
