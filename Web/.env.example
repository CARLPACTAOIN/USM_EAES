# =============================================================================
# USM Event Attendance & Evaluation System (EAES) — Laravel Backend
# Copy to .env and run: php artisan key:generate
# PRD: PRD_V1.md (mirror of repo root) | Agent workflow: AGENTS.md
# =============================================================================

# --- Application ---
APP_NAME="USM EAES"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Manila

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# --- Logging ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (PostgreSQL 16 — PRD §7) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=eaes
DB_USERNAME=postgres
DB_PASSWORD=
# DB_URL=
# DB_SSLMODE=prefer

# Quick local fallback (uncomment and set DB_CONNECTION=sqlite)
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

# --- Session (web portal) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax

# --- Local safety toggles ---
EAES_FORCE_HTTPS=false
EAES_SECURITY_HEADERS=true
EAES_ENABLE_DEV_LOGIN=false

# --- Cache & queue (Redis preferred for sync jobs — PRD §3.3) ---
CACHE_STORE=redis
QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Local-only fallback when Redis is not running:
# CACHE_STORE=database
# QUEUE_CONNECTION=database

# --- Redis ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# REDIS_QUEUE=default
# REDIS_CACHE_DB=1

MEMCACHED_HOST=127.0.0.1

# --- Mail ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@usm.edu.ph"
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS / S3 (optional exports or file storage) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Frontend & API clients ---
FRONTEND_URL=http://localhost:5173
VITE_APP_NAME="${APP_NAME}"
VITE_API_URL="${APP_URL}/api"

# Sanctum (after: php artisan install:api)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:8000
# SANCTUM_TOKEN_PREFIX=
# SANCTUM_EXPIRATION=43200

# CORS / mobile (wire in config when API is live)
# CORS_ALLOWED_ORIGINS="${FRONTEND_URL}"
# EAES_MOBILE_DEEP_LINK_SCHEME=eaes

# --- Google OAuth (Laravel Socialite — Epic 1.1) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# --- EAES institutional & domain rules ---
EAES_ALLOWED_EMAIL_DOMAIN=usm.edu.ph
EAES_UNIVERSITY_NAME="University of Southern Mindanao"

# --- Attendance sync (PRD §3.3) ---
EAES_SYNC_BATCH_SIZE=200
EAES_SYNC_CHUNK_SIZE=200

# --- Evaluation gate (PRD Epic 5.2) ---
EAES_EVALUATION_WINDOW_HOURS=24

# --- Google Gemini AI (PRD §6) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
# GEMINI_REQUEST_TIMEOUT=60
